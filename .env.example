# Copy this file to .env.local and fill in your key to enable the live AI vibe summary.
#   cp .env.example .env.local
#
# .env.local is gitignored and never committed. Without a key, the app still runs —
# the "Generate vibe summary" feature falls back to a clearly-labeled canned summary.
#
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
